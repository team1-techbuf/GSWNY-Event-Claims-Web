# Copy this file to .env.local for local frontend development.
# Do not commit .env.local.

# Firebase web app config from Firebase Console > Project settings > Your apps.
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=gswny-event-claims.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gswny-event-claims
VITE_FIREBASE_STORAGE_BUCKET=gswny-event-claims.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_APP_ID=replace-with-web-app-id

# Local Functions emulator:
# http://127.0.0.1:5001/gswny-event-claims/us-central1/api
#
# Deployed Firebase Hosting can leave this blank only if /api/** rewrites to
# the api Function through firebase.json.
VITE_API_BASE_URL=http://127.0.0.1:5001/gswny-event-claims/us-central1/api
