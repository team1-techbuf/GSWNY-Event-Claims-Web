# Copy this file to functions/.env for Firebase Functions emulator use.
# Do not commit functions/.env.

# Required: Google Sheet ID from the Sheet URL.
SHEET_ID=replace-with-google-sheet-id

# Required locally: choose ONE credential option.
#
# Option A: local uncommitted service account JSON path.
# Share the Google Sheet with this service account email.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option B: JSON string secret/env var. Leave blank if using option A.
# Use this as a deployed secret instead of committing any key material.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional compatibility alias for the same JSON string.
GOOGLE_SERVICE_ACCOUNT_KEY=

# Comma-separated browser origins allowed to call authenticated endpoints.
# Add the production Firebase Hosting URL after deploy, for example:
# https://gswny-event-claims.web.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
